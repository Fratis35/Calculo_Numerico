clear 
clc
clf()

x = [0, 1, 2, 3, 4, 4.5];
y = [0, 0.1763, 0.3640, 0.5774, 0.8391, 1];
plot(x,y)
h=1;

//1 Regra de Simpson (n impar >=5)
//1 4 1     1 4 2 4 2 ... 2 4 1
A = (1*h)/3 * ( y(1) + 4*y(2) + 2*y(3) + 4*y(4) + y(5))  +  (0.5)/2*(y(5) + y(6) );

//2 Regra de Simpson (n impar >=7)
//1 3 3 1    1 3 3 2 3 3 2 1
B = (3*h)/8 * ( y(1) + 3*y(2) + 3*y(3) + 2*y(4) + y(5))  +  (0.5)/2*(y(5) + y(6) );

disp([A, B])
